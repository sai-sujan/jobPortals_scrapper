# Optional local environment variables.
#
# Copy this file to .env or export the values in your shell if you need them.
# The scripts do not load .env automatically; run `source .env` before commands.

# Enables optional Groq/Llama AI filtering when a scraper is run with --ai-filter.
GROQ_API_KEY=

# Enables the Kforce Azure Search scraper.
# Without this key, Kforce is skipped gracefully and writes an empty output file.
KFORCE_AZURE_SEARCH_KEY=

# Optional default resume path for Apex application prefill.
JOB_PORTAL_RESUME=resume.docx
